# ─────────────────────────────────────────────────────────────────────────────
#  Deku-Service v3 — Variables d'environnement
#  Renommez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# ── GROQ API Key (obligatoire pour l'agent IA et Whisper) ─────────────────────
# Obtenez votre clé sur : https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Port HTTP (optionnel — Render/Heroku injectent $PORT automatiquement) ──────
# PORT=3000

# ── URL publique du service (optionnel — détectée automatiquement sur Render) ──
# RENDER_EXTERNAL_URL=https://votre-service.onrender.com
